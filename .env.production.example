APP_NAME=Virelle
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://tu-dominio-production.up.railway.app

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
BCRYPT_ROUNDS=12

LOG_CHANNEL=stderr
LOG_STACK=stderr
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=info

DB_CONNECTION=mysql
DB_HOST=tu-host-de-produccion
DB_PORT=25060
DB_DATABASE=defaultdb
DB_USERNAME=tu-usuario-de-produccion
DB_PASSWORD=tu-password-de-produccion

# DigitalOcean Managed MySQL requiere SSL. Si descargas el certificado CA,
# subelo como variable/archivo secreto y apunta esta ruta al certificado.
# MYSQL_ATTR_SSL_CA=/path/to/ca-certificate.crt

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
CACHE_STORE=database

MAIL_MAILER=resend
RESEND_KEY=
MAIL_FROM_ADDRESS=noreply@tu-dominio-verificado.com
MAIL_FROM_NAME=Virelle

TESTMAIL_ENABLED=false
AUTH_PASSWORD_RESET_THROTTLE=60

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
